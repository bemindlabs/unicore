{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "plugins": [
      { "name": "next" }
    ]
  }
}
