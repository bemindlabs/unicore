{
  "name": "@unicore/branding-base",
  "version": "0.1.0",
  "private": true,
  "description": "Base branding system — colors, fonts, dark/light mode theming for UniCore community edition",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "require": "./dist/types.js",
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./presets": {
      "require": "./dist/presets.js",
      "import": "./dist/presets.js",
      "types": "./dist/presets.d.ts"
    },
    "./service": {
      "require": "./dist/service.js",
      "import": "./dist/service.js",
      "types": "./dist/service.d.ts"
    },
    "./css-generator": {
      "require": "./dist/css-generator.js",
      "import": "./dist/css-generator.js",
      "types": "./dist/css-generator.d.ts"
    },
    "./tailwind": {
      "require": "./dist/tailwind.js",
      "import": "./dist/tailwind.js",
      "types": "./dist/tailwind.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx --test src/__tests__/presets.test.ts src/__tests__/css-generator.test.ts src/__tests__/service.test.ts src/__tests__/tailwind.test.ts",
    "lint": "echo 'no linter configured'"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
