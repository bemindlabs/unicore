{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "@bemindlabs/unicore-shared-types": ["../shared-types/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
