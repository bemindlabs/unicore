{
  "name": "@bemindlabs/unicore-integrations",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./adapters/stripe": {
      "types": "./dist/adapters/stripe/index.d.ts",
      "import": "./dist/adapters/stripe/index.js",
      "require": "./dist/cjs/adapters/stripe/index.js"
    },
    "./adapters/plaid": {
      "types": "./dist/adapters/plaid/index.d.ts",
      "import": "./dist/adapters/plaid/index.js",
      "require": "./dist/cjs/adapters/plaid/index.js"
    },
    "./adapters/email": {
      "types": "./dist/adapters/email/index.d.ts",
      "import": "./dist/adapters/email/index.js",
      "require": "./dist/cjs/adapters/email/index.js"
    },
    "./adapters/tiktok": {
      "types": "./dist/adapters/tiktok/index.d.ts",
      "import": "./dist/adapters/tiktok/index.js",
      "require": "./dist/cjs/adapters/tiktok/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json",
    "typecheck": "tsc --noEmit",
    "test": "npx jest --passWithNoTests",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@bemindlabs/unicore-shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/nodemailer": "^6.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
