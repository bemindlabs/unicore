# ============================================================================
# UniCore Community Edition — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables have sensible defaults
# ============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=unicore
POSTGRES_PASSWORD=change-me-strong-password        # [REQUIRED] Change in production
POSTGRES_DB=unicore
POSTGRES_DB_ERP=unicore_erp
POSTGRES_DB_LICENSE=unicore_license

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-generate-strong-32-char-secret  # [REQUIRED] Min 32 chars
BOOTSTRAP_SECRET=change-me-bootstrap-secret          # [REQUIRED] Wizard provisioning auth
LICENSE_ADMIN_SECRET=change-me-license-secret         # [REQUIRED] License server auth

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000             # Dashboard API base URL
# NEXT_PUBLIC_WS_URL=ws://localhost:18789             # WebSocket URL (auto-detected)
# NEXT_PUBLIC_EDITION=community                       # community | pro

# ── Infrastructure (usually keep defaults) ───────────────────────────────────
# NODE_ENV=production                                # production | development
# QDRANT_URL=http://unicore-vectordb:6333            # Vector DB (internal)
# KAFKA_BROKERS=unicore-kafka:9092                   # Kafka (internal)
# REDIS_URL=redis://unicore-redis:6379               # Redis (internal)
