DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unicore?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production"
PORT=4000

# License key for Pro/Enterprise tier features.
# Leave unset to run in Community tier (free, no Pro features).
# Obtain a key from https://unicore.io/pricing
UNICORE_LICENSE_KEY=

# License server URL (optional — defaults to http://unicore-license-api:4600 for Docker deployments).
# Override for on-premise deployments or local development with a test license server.
LICENSE_SERVER_URL=

# Downstream service addresses
ERP_SERVICE_HOST=localhost
ERP_SERVICE_PORT=4100
AI_ENGINE_SERVICE_HOST=localhost
AI_ENGINE_SERVICE_PORT=4200
RAG_SERVICE_HOST=localhost
RAG_SERVICE_PORT=4300
BOOTSTRAP_SERVICE_HOST=localhost
BOOTSTRAP_SERVICE_PORT=4500

# Rate limiting
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_USER_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# Request validation
MAX_REQUEST_BODY_BYTES=1048576

# Custom domain routing (UNC-55)
# Comma-separated list of hostnames/domains that belong to the platform itself.
# Requests to these hosts bypass custom-domain resolution.
PLATFORM_DOMAINS=localhost,unicore.io
# TTL (seconds) for Redis-cached domain→tenant mappings (default: 300 = 5 min)
DOMAIN_CACHE_TTL_SECONDS=300
# Redis key prefix for domain cache entries
DOMAIN_CACHE_KEY_PREFIX=domain:
