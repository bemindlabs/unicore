# ERP Service — environment variables
# Copy to .env and fill in your values

# PostgreSQL 16 connection string
DATABASE_URL="postgresql://unicore:unicore@localhost:5432/unicore_erp?schema=public"

# Kafka brokers (comma-separated)
KAFKA_BROKERS="localhost:9092"

# HTTP port (default: 4100)
PORT=4100

# Node environment
NODE_ENV=development
