datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// Individual persisted WebSocket messages for history, replay, and dashboard load.
model ChatMessage {
  id          String   @id @default(uuid())
  messageId   String   @unique
  channel     String
  fromAgentId String
  data        Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([channel])
  @@index([channel, createdAt])
  @@index([fromAgentId])
  @@map("chat_messages")
}

// Conversation records for the Omni-Channel Conversation Hub (UNC-1025).
// Tracks WebSocket-level conversation lifecycle per agent.
model Conversation {
  id           String   @id @default(uuid())
  agentId      String
  userId       String
  userChannel  String
  // OPEN | ASSIGNED | RESOLVED | CLOSED
  status       String   @default("OPEN")
  assignedTo   String?
  assignedName String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([agentId])
  @@index([userId])
  @@index([status])
  @@index([agentId, status])
  @@map("conversations")
}
