# Server
PORT=4300
NODE_ENV=development

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# AI Engine (embedding provider)
AI_ENGINE_URL=http://localhost:4200
AI_ENGINE_API_KEY=

# Embedding config
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Chunking config
CHUNK_SIZE=512
CHUNK_OVERLAP=64
