{
  "name": "unicore",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "prisma": "prisma",
    "test:e2e": "playwright test",
    "test:e2e:dashboard": "playwright test --project=dashboard",
    "test:e2e:platform": "playwright test --project=platform",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:ui": "playwright test --ui"
  },
  "pnpm": {
    "overrides": {
      "react": "^18.3.0",
      "react-dom": "^18.3.0",
      "glob": ">=10.5.0",
      "multer": ">=2.1.1",
      "file-type": ">=21.3.2",
      "webpack": ">=5.104.1",
      "@tootallnate/once": ">=3.0.1",
      "flatted": ">=3.4.2",
      "effect": ">=3.20.0",
      "@prisma/config>effect": ">=3.20.0",
      "lodash": ">=4.17.23",
      "tmp": ">=0.2.4"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "prisma": "^6.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "version": "0.1.2"
}
